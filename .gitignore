# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Local environment and editor state
.env
.env.*
.idea/
.vscode/

# Native build outputs
cpp_runtime/build/
build/
dist/

# Local runtime data
external_data/
python_agent/data/cache/
python_agent/data/feedback/*.jsonl
python_agent/data/logs/*.jsonl
python_agent/data/settings/*.json
python_agent/data/user_apps/
